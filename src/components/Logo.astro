---
interface Props {
  variant?: 'dark' | 'light';
  class?: string;
}
const { variant = 'dark', class: cls = '' } = Astro.props;
const fg = variant === 'dark' ? '#0A0A0B' : '#FFFFFF';
const accent = '#C8102E';
---

<a href="/" aria-label="MG AlHabiba home" class={`inline-flex items-center gap-3 ${cls}`}>
  <svg width="44" height="44" viewBox="0 0 44 44" aria-hidden="true">
    <rect x="1" y="1" width="42" height="42" rx="10" fill={accent} />
    <rect x="1" y="1" width="42" height="42" rx="10" fill="none" stroke={accent} stroke-width="2" />
    <text
      x="22"
      y="28"
      text-anchor="middle"
      font-family="Inter, sans-serif"
      font-weight="800"
      font-size="18"
      fill="white"
      letter-spacing="-0.5"
    >MG</text>
  </svg>
  <span class="flex flex-col leading-none">
    <span class="text-[0.6875rem] font-semibold uppercase tracking-[0.18em]" style={`color:${accent}`}>AlHabiba</span>
    <span class="text-base font-bold tracking-tight" style={`color:${fg}`}>Auto Service</span>
  </span>
</a>
