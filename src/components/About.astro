---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const points = ['about.point1','about.point2','about.point3','about.point4'] as const;
---

<section id="about" class="py-20 md:py-32" style="background: var(--color-ink); color: white;">
  <div class="container-x grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
    <div class="lg:col-span-6">
      <div class="relative aspect-[5/4] rounded-3xl overflow-hidden">
        <div class="absolute inset-0" style="background: linear-gradient(135deg, #C8102E 0%, #9A0C24 100%);"></div>
        <svg viewBox="0 0 500 400" class="absolute inset-0 w-full h-full opacity-40" aria-hidden="true">
          <defs>
            <pattern id="ap" x="0" y="0" width="50" height="50" patternUnits="userSpaceOnUse">
              <circle cx="2" cy="2" r="1.5" fill="white" />
            </pattern>
          </defs>
          <rect width="500" height="400" fill="url(#ap)" />
        </svg>
        <div class="absolute inset-0 flex items-center justify-center">
          <div class="text-center text-white">
            <div class="text-6xl md:text-8xl font-extrabold tracking-tight">10+</div>
            <div class="mt-3 text-xs uppercase tracking-[0.25em] font-semibold opacity-90">Years of expertise</div>
          </div>
        </div>
      </div>
    </div>

    <div class="lg:col-span-6">
      <span class="eyebrow" style="color: #F0788C;">{t('about.eyebrow')}</span>
      <h2 class="heading mt-5 text-3xl sm:text-4xl md:text-5xl">{t('about.title')}</h2>
      <p class="mt-5 text-base md:text-lg" style="color: rgba(255,255,255,0.78);">{t('about.p1')}</p>
      <p class="mt-3 text-base md:text-lg" style="color: rgba(255,255,255,0.78);">{t('about.p2')}</p>

      <ul class="mt-8 grid sm:grid-cols-2 gap-3">
        {points.map((p) => (
          <li class="flex items-start gap-3 text-sm md:text-base">
            <span class="mt-0.5 inline-flex w-5 h-5 rounded-full items-center justify-center shrink-0" style="background: var(--color-mg-red);">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            <span style="color: rgba(255,255,255,0.9);">{t(p)}</span>
          </li>
        ))}
      </ul>
    </div>
  </div>
</section>
