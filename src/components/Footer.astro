---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
import Logo from './Logo.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

const links = [
  { href: '#services', label: t('nav.services') },
  { href: '#about', label: t('nav.about') },
  { href: '#gallery', label: t('nav.gallery') },
  { href: '#location', label: t('nav.location') },
  { href: '#book', label: t('nav.book') },
];
---

<footer class="py-14 md:py-16" style="background: var(--color-bone-soft); color: var(--color-ink);">
  <div class="container-x grid md:grid-cols-12 gap-10">
    <div class="md:col-span-5">
      <Logo />
      <p class="mt-4 text-sm max-w-sm" style="color: var(--color-ink-muted);">
        {t('footer.tagline')}
      </p>
    </div>

    <div class="md:col-span-3">
      <h4 class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-ink-muted);">{t('footer.quickLinks')}</h4>
      <ul class="mt-4 space-y-2 text-sm">
        {links.map((l) => (
          <li><a href={l.href} class="hover:text-[var(--color-mg-red)] transition-colors">{l.label}</a></li>
        ))}
      </ul>
    </div>

    <div class="md:col-span-4">
      <h4 class="text-xs font-bold uppercase tracking-widest" style="color: var(--color-ink-muted);">{t('footer.contact')}</h4>
      <ul class="mt-4 space-y-2 text-sm">
        <li>{t('location.address.value')}</li>
        <li><a href="tel:+201207777225" class="hover:underline">0120 777 7225</a></li>
        <li>
          <a href="https://wa.me/201207777225" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-[var(--color-mg-red)] transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M20.52 3.48A11.94 11.94 0 0 0 12.04 0C5.46 0 .12 5.34.12 11.92c0 2.1.55 4.14 1.6 5.95L0 24l6.27-1.64a11.93 11.93 0 0 0 5.77 1.47h.01c6.58 0 11.92-5.34 11.92-11.92 0-3.18-1.24-6.18-3.49-8.43zM12.05 21.8h-.01a9.86 9.86 0 0 1-5.02-1.38l-.36-.21-3.72.97 1-3.63-.24-.37a9.85 9.85 0 0 1-1.51-5.25c0-5.46 4.44-9.9 9.9-9.9 2.65 0 5.13 1.03 7 2.9a9.83 9.83 0 0 1 2.9 7c-.01 5.46-4.45 9.87-9.94 9.87z"/>
            </svg>
            WhatsApp
          </a>
        </li>
        <li>
          <a href="https://www.facebook.com/ALhabiba.MG/" target="_blank" rel="noopener" class="inline-flex items-center gap-2 hover:text-[var(--color-mg-red)] transition-colors">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M22 12a10 10 0 1 0-11.56 9.88v-6.99H7.9V12h2.54V9.8c0-2.5 1.49-3.89 3.78-3.89 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56V12h2.77l-.44 2.89h-2.33v6.99A10 10 0 0 0 22 12z"/>
            </svg>
            Facebook
          </a>
        </li>
      </ul>
    </div>
  </div>

  <div class="container-x mt-12 pt-6 hairline flex flex-col md:flex-row md:items-center md:justify-between gap-2 text-xs" style="color: var(--color-ink-muted);">
    <span>© {year} AlHabiba Auto. {t('footer.rights')}</span>
    <span class="inline-flex items-center gap-1.5">
      {t('footer.madeWith')}
      <span aria-hidden="true" style="color: var(--color-mg-red);">♥</span>
      {t('footer.madeBy')}
      <a
        href="https://omartahersaad.com"
        target="_blank"
        rel="noopener"
        class="font-semibold hover:text-[var(--color-mg-red)] transition-colors"
        style="color: var(--color-ink);"
      >OTS</a>
    </span>
  </div>
</footer>
