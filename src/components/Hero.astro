---
import { getLangFromUrl, useTranslations } from '../i18n/ui';
const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="relative overflow-hidden bg-bone">
  <div class="absolute inset-0 grid-bg opacity-60" aria-hidden="true"></div>
  <div
    class="absolute -top-32 -right-32 w-[36rem] h-[36rem] rounded-full blur-3xl opacity-25"
    style="background: radial-gradient(circle, #C8102E 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="container-x relative pt-12 md:pt-20 pb-16 md:pb-28">
    <div class="grid lg:grid-cols-12 gap-10 lg:gap-16 items-center">
      <div class="lg:col-span-7">
        <span class="eyebrow animate-fade-up">{t('hero.eyebrow')}</span>
        <h1 class="heading mt-5 text-4xl sm:text-5xl md:text-6xl lg:text-7xl animate-fade-up delay-1">
          {t('hero.title')}<br />
          <span style="color: var(--color-mg-red);">{t('hero.titleAccent')}</span>
        </h1>
        <p class="mt-6 max-w-xl text-base md:text-lg animate-fade-up delay-2" style="color: var(--color-ink-muted);">
          {t('hero.subtitle')}
        </p>

        <div class="mt-8 flex flex-wrap gap-3 animate-fade-up delay-3">
          <a href="#book" class="btn btn-primary">
            {t('hero.ctaBook')}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M13 5l7 7-7 7" />
            </svg>
          </a>
          <a href="tel:+201207777225" class="btn btn-ghost">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            {t('hero.ctaCall')}
          </a>
        </div>

        <dl class="mt-12 grid grid-cols-3 gap-4 sm:gap-8 max-w-xl animate-fade-up delay-4">
          {[1,2,3].map((i) => (
            <div class="border-t border-black/10 pt-4">
              <dt class="text-2xl md:text-3xl font-bold tracking-tight" style="color: var(--color-ink);">
                {t(`hero.stat${i}.num` as any)}
              </dt>
              <dd class="mt-1 text-xs md:text-sm" style="color: var(--color-ink-muted);">
                {t(`hero.stat${i}.label` as any)}
              </dd>
            </div>
          ))}
        </dl>
      </div>

      <div class="lg:col-span-5 relative">
        <div class="relative aspect-[4/5] rounded-3xl overflow-hidden shadow-[0_24px_60px_-20px_rgba(10,10,11,0.35)]">
          <div class="absolute inset-0" style="background: linear-gradient(180deg, #1A1A1D 0%, #0A0A0B 100%);"></div>
          <svg viewBox="0 0 400 500" class="absolute inset-0 w-full h-full" aria-hidden="true">
            <defs>
              <linearGradient id="hg" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#C8102E" stop-opacity="0.9"/>
                <stop offset="100%" stop-color="#C8102E" stop-opacity="0"/>
              </linearGradient>
              <pattern id="hp" x="0" y="0" width="40" height="40" patternUnits="userSpaceOnUse">
                <path d="M 40 0 L 0 0 0 40" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
              </pattern>
            </defs>
            <rect width="400" height="500" fill="url(#hp)"/>
            <circle cx="320" cy="120" r="180" fill="url(#hg)"/>
            <g transform="translate(80, 200)">
              <path d="M 0 80 Q 20 30 80 30 L 160 30 Q 200 30 220 60 L 240 80 L 240 130 L 0 130 Z" fill="#1A1A1D" stroke="rgba(255,255,255,0.15)" stroke-width="1.5"/>
              <circle cx="60" cy="130" r="22" fill="#0A0A0B" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <circle cx="60" cy="130" r="10" fill="#C8102E"/>
              <circle cx="190" cy="130" r="22" fill="#0A0A0B" stroke="rgba(255,255,255,0.3)" stroke-width="1.5"/>
              <circle cx="190" cy="130" r="10" fill="#C8102E"/>
              <rect x="40" y="50" width="160" height="35" rx="8" fill="rgba(200,16,46,0.15)" stroke="rgba(200,16,46,0.4)" stroke-width="1"/>
            </g>
            <g transform="translate(160, 60)">
              <rect x="0" y="0" width="80" height="80" rx="18" fill="#C8102E"/>
              <text x="40" y="52" text-anchor="middle" font-family="Inter" font-weight="800" font-size="32" fill="white">MG</text>
            </g>
          </svg>
          <div class="absolute bottom-6 inset-x-6 flex items-center justify-between text-white/90">
            <div class="flex items-center gap-2 text-xs uppercase tracking-widest font-semibold">
              <span class="w-2 h-2 rounded-full" style="background: #22c55e;"></span>
              Authorized
            </div>
            <div class="text-xs font-medium opacity-80">Est. AlHabiba</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
